{
  "name": "crx-vite-ts-react-template",
  "version": "1.0.0",
  "description": "Chrome extension template using Vite, TypeScript and React",
  "main": "index.js",
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "build": "rm -rf extension && vite build",
    "preview": "vite preview",
    "zip": "npm run build && rm -f extension.zip && zip -r extension.zip extension",
    "lint:prettier": "prettier --write '{src,tools}/**/*.{js,ts,tsx}'",
    "lint:eslint": "eslint --fix '{src,tools}/**/*.{js,ts,tsx}'",
    "lint": "npm run lint:prettier && npm run lint:eslint",
    "check-type": "tsc --noEmit",
    "test": "vitest run",
    "docs": "rm -rf docs && cp -r gh-pages docs && npm run zip && mv extension.zip docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/50ra4/crx-vite-ts-react-template.git"
  },
  "author": "50ra4",
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "bugs": {
    "url": "https://github.com/50ra4/crx-vite-ts-react-template/issues"
  },
  "homepage": "https://github.com/50ra4/crx-vite-ts-react-template#readme",
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "5.32.0",
    "@typescript-eslint/parser": "5.32.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "8.21.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-react": "7.30.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "husky": "8.0.1",
    "jsdom": "29.1.1",
    "prettier": "2.7.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
